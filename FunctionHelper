local function showTooltip(text, anchorAbsPos, anchorAbsSize)
    TooltipLabel.Text = text
    local tw = TextService:GetTextSize(text, 11, Enum.Font.Gotham, Vector2.new(300, 26)).X + 16
    TooltipFrame.Size = UDim2.new(0, tw, 0, 26)
    local x = anchorAbsPos.X + anchorAbsSize.X / 2 - tw / 2
    local y = anchorAbsPos.Y - 30
    TooltipFrame.Position = UDim2.new(0, x, 0, y)
    TooltipFrame.Visible = true
end

local function hideTooltip()
    TooltipFrame.Visible = false
end

-- Attach tooltip to any GuiObject
local function withTooltip(obj, text)
    obj.MouseEnter:Connect(function()
        showTooltip(text, obj.AbsolutePosition, obj.AbsoluteSize)
    end)
    obj.MouseLeave:Connect(hideTooltip)
end

