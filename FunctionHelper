local function makeWinBtn(name, icon, xOffset, hoverColor)
    local b = button{
        name     = name,
        bg       = Color3.new(0,0,0),
        bgT      = 1,
        size     = UDim2.new(0, 24, 0, 24),
        pos      = UDim2.new(0, xOffset, 0.5, -12),
        text     = icon,
        font     = Enum.Font.GothamBold,
        textSize = 14,
        color    = T.textSecondary,
        parent   = WinBtns,
    }
    corner(b, 5)
    b.MouseEnter:Connect(function()
        tween(b, 0.12, {BackgroundTransparency = 0, TextColor3 = hoverColor or T.textPrimary})
        b.BackgroundColor3 = hoverColor and T.redDim or T.hover
    end)
    b.MouseLeave:Connect(function()
        tween(b, 0.12, {BackgroundTransparency = 1, TextColor3 = T.textSecondary})
    end)
    return b
end

