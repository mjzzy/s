end

--- TextBox factory
local function textbox(props)
    local tb = Instance.new("TextBox")
    tb.BackgroundColor3 = props.bg or T.surface
    tb.BackgroundTransparency = props.bgT or 0
    tb.BorderSizePixel = 0
    tb.Size = props.size or UDim2.new(1, 0, 1, 0)
    tb.Position = props.pos or UDim2.new(0, 0, 0, 0)
    tb.Text = props.text or ""
    tb.PlaceholderText = props.placeholder or ""
    tb.PlaceholderColor3 = props.phColor or T.textMuted
    tb.Font = props.font or Enum.Font.Gotham
    tb.TextSize = props.textSize or 12
    tb.TextColor3 = props.color or T.textPrimary
    tb.TextXAlignment = props.xAlign or Enum.TextXAlignment.Left
    tb.ClearTextOnFocus = false
    tb.Name = props.name or "TextBox"
    tb.Parent = props.parent
    return tb
end

--- ScrollingFrame factory
local function scroller(props)
    local s = Instance.new("ScrollingFrame")
    s.BackgroundColor3 = props.bg or T.surface
    s.BackgroundTransparency = props.bgT or 1
    s.BorderSizePixel = 0
    s.Size = props.size or UDim2.new(1, 0, 1, 0)
    s.Position = props.pos or UDim2.new(0, 0, 0, 0)
    s.CanvasSize = props.canvas or UDim2.new(0, 0, 0, 0)
    s.AutomaticCanvasSize = props.autoCanvas or Enum.AutomaticSize.Y
    s.ScrollBarThickness = props.scrollBar or 3
    s.ScrollBarImageColor3 = T.border
    s.ScrollingDirection = Enum.ScrollingDirection.Y
    s.ClipsDescendants = true
    s.Name = props.name or "Scroller"
    s.Parent = props.parent
    return s
end

--- ImageLabel factory
local function img(props)
    local i = Instance.new("ImageLabel")
    i.BackgroundTransparency = 1
    i.BorderSizePixel = 0
    i.Size = props.size or UDim2.new(0, 16, 0, 16)
    i.Position = props.pos or UDim2.new(0, 0, 0, 0)
    i.Image = props.image or ""
    i.ImageColor3 = props.color or T.textSecondary
    i.Name = props.name or "Image"
    i.Parent = props.parent
    return i
end

