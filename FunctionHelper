    RF = { bg = T.badgeRFdim, text = T.badgeRF  },
    UF = { bg = T.badgeUFdim, text = T.badgeUF  },
}

-- Syntax-highlight a code string into RichText (basic keywords)
local kwMap = {
    ["local"] = T.synKeyword, ["function"] = T.synKeyword,
    ["end"] = T.synKeyword,   ["if"] = T.synKeyword,
    ["then"] = T.synKeyword,  ["else"] = T.synKeyword,
    ["elseif"] = T.synKeyword,["return"] = T.synKeyword,
    ["true"] = T.synNumber,   ["false"] = T.synNumber,
    ["nil"] = T.synNumber,    ["and"] = T.synKeyword,
    ["or"] = T.synKeyword,    ["not"] = T.synKeyword,
    ["for"] = T.synKeyword,   ["do"] = T.synKeyword,
    ["while"] = T.synKeyword, ["repeat"] = T.synKeyword,
    ["until"] = T.synKeyword, ["in"] = T.synKeyword,
    ["unpack"] = T.synFunction,["pairs"] = T.synFunction,
    ["ipairs"] = T.synFunction,["game"] = T.synFunction,
    ["workspace"] = T.synFunction,
}

local function colHex(c)
    return string.format("%02x%02x%02x",
        math.floor(c.R * 255),
        math.floor(c.G * 255),
        math.floor(c.B * 255))
end

local function escRich(s)
    return s:gsub("&","&amp;"):gsub("<","&lt;"):gsub(">","&gt;")
end

local function highlight(code)
    -- Very lightweight: colour string literals, numbers, comments, keywords
    local result = {}
    local i = 1
    local len = #code
    while i <= len do
        local ch = code:sub(i, i)
        -- Comments
        if code:sub(i, i+1) == "--" then
            local eol = code:find("\n", i) or len + 1
            local segment = escRich(code:sub(i, eol - 1))
            result[#result+1] = '<font color="#'..colHex(T.synComment)..'">'..segment..'</font>'
            i = eol
        -- String literals
        elseif ch == '"' or ch == "'" then
            local delim = ch
            local j = i + 1
            while j <= len do
                if code:sub(j,j) == "\\" then j = j + 2
                elseif code:sub(j,j) == delim then j = j + 1; break
                else j = j + 1 end
            end
            local segment = escRich(code:sub(i, j-1))
            result[#result+1] = '<font color="#'..colHex(T.synString)..'">'..segment..'</font>'
            i = j
        -- Numbers
        elseif ch:match("%d") and (i == 1 or not code:sub(i-1,i-1):match("%a_")) then
            local j = i
            while j <= len and (code:sub(j,j):match("%d") or code:sub(j,j) == ".") do j = j + 1 end
            result[#result+1] = '<font color="#'..colHex(T.synNumber)..'">'..escRich(code:sub(i,j-1))..'</font>'
            i = j
        -- Identifiers / keywords
        elseif ch:match("[%a_]") then
            local j = i
            while j <= len and code:sub(j,j):match("[%a%d_]") do j = j + 1 end
            local word = code:sub(i, j-1)
            if kwMap[word] then
                result[#result+1] = '<font color="#'..colHex(kwMap[word])..'">'..escRich(word)..'</font>'
            else
                result[#result+1] = escRich(word)
            end
            i = j
        else
            result[#result+1] = escRich(ch)
            i = i + 1
        end
    end
    return table.concat(result)
end

local function addLogEntry(info)
    local bcol = badgeColors[info.remType] or badgeColors["RE"]

    -- Entry row
    local entry = frame{
        name   = "Entry_"..info.name,
        bg     = T.surface,
        size   = UDim2.new(1, 0, 0, 32),
        parent = LogScroll,
    }
    entry.LayoutOrder = -os.clock() -- descending (newest first)

    -- Left accent line (shows when selected)
    local Accent = frame{
        name   = "Accent",
        bg     = T.accent,
        size   = UDim2.new(0, 2, 1, 0),
        parent = entry,
    }
    Accent.Visible = false

    -- Type badge
    local Badge = frame{
        name   = "Badge",
        bg     = bcol.bg,
        size   = UDim2.new(0, 24, 0, 15),
        pos    = UDim2.new(0, 10, 0.5, -7),
        parent = entry,
    }
    corner(Badge, 3)
    local BadgeLabel = label{
        text     = info.remType,
        font     = Enum.Font.GothamBold,
        textSize = 8,
        color    = bcol.text,
        xAlign   = Enum.TextXAlignment.Center,
        parent   = Badge,
    }

    -- Remote name
    local NameLabel = label{
        name     = "Name",
        text     = info.name,
        font     = Enum.Font.Gotham,
        textSize = 11,
        color    = T.textSecondary,
        size     = UDim2.new(1, -44, 1, 0),
        pos      = UDim2.new(0, 40, 0, 0),
        xAlign   = Enum.TextXAlignment.Left,
        parent   = entry,
    }

    -- Bottom divider
    local EntryDiv = frame{
        bg     = T.borderFaint,
        size   = UDim2.new(1, 0, 0, 1),
        pos    = UDim2.new(0, 0, 1, -1),
        parent = entry,
    }

    -- Hover / select interaction
    local isSelected = false

    local function select()
        -- Deselect old
        if selectedEntry and selectedEntry ~= entry then
            local oldAccent = selectedEntry:FindFirstChild("Accent")
            local oldName   = selectedEntry:FindFirstChild("Name")
            if oldAccent then oldAccent.Visible = false end
            if oldName   then tween(oldName, 0.1, {TextColor3 = T.textSecondary}) end
            tween(selectedEntry, 0.1, {BackgroundColor3 = T.surface})
        end
        selectedEntry = entry
        isSelected = true
        Accent.Visible = true
        tween(entry, 0.1, {BackgroundColor3 = T.selected})
        tween(NameLabel, 0.1, {TextColor3 = T.textPrimary})

        -- Populate right panel
        local gen   = info.genCode  or "-- No generated script."
        local raw   = info.rawArgs  or "-- No raw args."
        local stk   = info.stack    or "-- No call stack captured."
        CodeLabel.Text  = highlight(gen)
        RawLabel.Text   = highlight(raw)
        StackLabel.Text = highlight(stk)

        -- Switch to generated tab
        switchTab("generated")
    end

    local clickBtn = button{
        bg     = T.surface,
        bgT    = 1,
        size   = UDim2.new(1, 0, 1, 0),
        text   = "",
        parent = entry,
    }
    clickBtn.ZIndex = 3

    clickBtn.MouseButton1Click:Connect(select)
    clickBtn.MouseEnter:Connect(function()
        if not isSelected then
            tween(entry, 0.1, {BackgroundColor3 = T.hover})
        end
    end)
    clickBtn.MouseLeave:Connect(function()
        if not isSelected then
            tween(entry, 0.1, {BackgroundColor3 = T.surface})
        end
    end)

    table.insert(logEntries, 1, entry)
    return entry
end

