-- Safe Orion loader (default: local-only, telemetry disabled)
-- Place a vetted copy of Orion in Scripts/Orion.lua to use it locally.
local ORION_URL = "https://raw.githubusercontent.com/jensonhirst/Orion/main/source"
local LOCAL_PATH = "Scripts/Orion.lua"         -- relative file saved by you (trusted)
local TRUST_REMOTE = false                    -- set true only if you explicitly trust the remote URL
local TRUST_ICONS = false                     -- set true to allow loading icons from external JSON (optional)

local HttpService = game:GetService("HttpService")
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

local function try_load_from_string(body)
    local ok, libOrErr = pcall(function() return loadstring(body)() end)
    if ok then return libOrErr end
    return nil, libOrErr
end

local function try_load_local()
    if (type(isfile) == "function") and isfile(LOCAL_PATH) then
        local body = readfile(LOCAL_PATH)
        local lib, err = try_load_from_string(body)
        if lib then return lib end
        warn("Local Orion failed to load: " .. tostring(err))
    end
    return nil
end

local function try_load_remote()
    if not TRUST_REMOTE then
        warn("Remote loading disabled by default. Set TRUST_REMOTE = true to allow remote load.")
        return nil
    end
    local ok, body = pcall(function() return game:HttpGet(ORION_URL) end)
    if not ok or not body or #body == 0 then
        warn("Failed to fetch remote Orion: " .. tostring(body))
        return nil
    end
    -- NOTE: remote code may contain telemetry. We intentionally do NOT auto-run reporter/analytics.
    -- If you must run remote code, verify it manually or host a vetted copy and set TRUST_REMOTE to true.
    local lib, err = try_load_from_string(body)
    if not lib then warn("Remote Orion load failed: " .. tostring(err)) end
    return lib
end

-- load icons safely (optional)
local function safe_load_icons(url)
    if not TRUST_ICONS then
        return nil
    end
    local ok, json = pcall(function() return game:HttpGet(url) end)
    if not ok or not json then return nil end
    local ok2, decoded = pcall(function() return HttpService:JSONDecode(json) end)
    if not ok2 or type(decoded) ~= "table" or not decoded.icons then
        return nil
    end
    return decoded.icons
end

-- Try local first, then remote if explicitly allowed
local OrionLib = try_load_local() or try_load_remote()

-- Optionally load icons (safe only if TRUST_ICONS = true)
local icons = safe_load_icons("https://raw.githubusercontent.com/evoincorp/lucideblox/master/src/modules/util/icons.json")
if icons then
    -- provide a GetIcon helper for the loaded Orion environment if needed
    pcall(function()
        if OrionLib and type(OrionLib) == "table" then
            OrionLib._ExternalIcons = icons
        end
    end)
end

-- If Orion failed to load, provide a small safe fallback UI (minimal, local-only)
if not OrionLib then
    warn("Orion not loaded. Using local fallback UI. To use Orion, place a trusted copy at '" .. LOCAL_PATH .. "' or set TRUST_REMOTE = true after vetting.")
    -- Minimal fallback (example)
    local Players = game:GetService("Players")
    local LocalPlayer = Players.LocalPlayer
    if not LocalPlayer then return end
    local function mk(parent, class, props)
        local inst = Instance.new(class)
        if props then for k,v in pairs(props) do pcall(function() inst[k]=v end) end
        inst.Parent = parent
        return inst
    end
    local screen = mk(game.CoreGui, "ScreenGui", {Name="MizzX_FallbackGUI", ResetOnSpawn=false})
    local frame = mk(screen, "Frame", {Size=UDim2.new(0,340,0,180), Position=UDim2.new(0.5,-170,0.1,0), BackgroundColor3=Color3.fromRGB(25,25,25), BorderSizePixel=0})
    local title = mk(frame,"TextLabel",{Size=UDim2.new(1,-12,0,28), Position=UDim2.new(0,6,0,6), BackgroundTransparency=1, Text="MizzX - Fallback GUI", TextColor3=Color3.fromRGB(220,220,220), Font=Enum.Font.GothamBold, TextSize=18, TextXAlignment=Enum.TextXAlignment.Left})
    -- add buttons/controls similar to earlier fallback if desired...
end

return OrionLib
